{
  "version": "2.0",
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      },
      "enableLiveMetricsFilters": true
    },
    "logLevel": {
      "default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "SchedulingAgent": "Debug"
    }
  },
  "extensions": {
    "http": {
      "routePrefix": "api"
    },
    "cosmosDB": {
      "connectionMode": "Direct"
    }
  }
}
